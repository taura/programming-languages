.SHELLFLAGS := -eu -o pipefail -c

#
# tools
#
mk_nb := ../../jupyter_tools/authoring/mk_nb.py

#
# sed expressions that strip the begin/end hidden|skeleton markers:
#   problem : drop the hidden body, keep the skeleton (remove its marker lines)
#   answer  : drop the skeleton, keep the hidden body (remove its marker lines)
# a file with no markers passes through unchanged.
#
sed_problem := -e '/begin hidden/,/end hidden/d' -e '/begin skeleton/d' -e '/end skeleton/d'
sed_answer  := -e '/begin skeleton/,/end skeleton/d' -e '/begin hidden/d' -e '/end hidden/d'

in_dir   := ps
prob_dir := problems
ans_dir  := answers

# instantiate a rule generated by a define.
# flip to the $(info ...) variant to print the generated rules for debugging.
EVAL=$(eval $(1))
#EVAL=$(info $(1))

.DEFAULT_GOAL := compile
.PHONY : compile deploy check clean

#
# ============================================================
# [1] notebooks
#   nb/source/X/Y.py -> notebooks/source/X/Y.ipynb       (for students)
#                    -> notebooks/source/ans_X/Y.ipynb   (answer)
# ============================================================
#
nb_pys := $(wildcard nb/source/*/*.py)

define nb_rule
compile : notebooks/source/$(patsubst nb/source/%.py,%.ipynb,$(py))
notebooks/source/$(patsubst nb/source/%.py,%.ipynb,$(py)) : $(py)
	@mkdir -p $$(@D)
	$(mk_nb) --output $$@ $$<
compile : notebooks/source/ans_$(patsubst nb/source/%.py,%.ipynb,$(py))
notebooks/source/ans_$(patsubst nb/source/%.py,%.ipynb,$(py)) : $(py)
	@mkdir -p $$(@D)
	$(mk_nb) --output $$@ --labels ans $$<
endef
$(foreach py,$(nb_pys),$(call EVAL,$(call nb_rule)))

#
# ============================================================
# [1b] minC compiler problem  (deployed under problems/ for gen_problem)
#   TOPIC = minc, a single PROBLEM = minc that covers all four languages, laid
#   out like the other topics (problems/TOPIC/PROBLEM/...):
#     ps/minc/minc/minc.py                 the problem notebook (all languages)
#     ps/minc/minc/{minc.md,minc_grammar.txt,test/}   shared
#     ps/minc/minc/<lang>/minc/<files>     each language's compiler (with markers)
#   It deploys to problems/minc/minc/ (and answers/minc/minc/):
#     minc.ipynb  minc.md  minc_grammar.txt  test/
#     <lang>/minc/<files>   problem version (stubs)
#     <lang>/orig/<files>   identical pristine copy of <lang>/minc (problems only)
#   answers/ holds the full (answer) code instead of the stubs.
# A compiler source file is filtered through sed (markers stripped); files with
# no markers pass through unchanged, so copy vs transform need not be told apart.
# ============================================================
#
minc_src := ps/minc/minc

# compiler source files (under <minc_src>/<lang>/minc/...) — markers stripped at deploy
minc_code :=
minc_code += $(wildcard $(minc_src)/go/minc/*.go) $(wildcard $(minc_src)/go/minc/go.mod)
minc_code += $(wildcard $(minc_src)/jl/minc/*.jl)
minc_code += $(wildcard $(minc_src)/ml/minc/lib/*.ml) $(wildcard $(minc_src)/ml/minc/bin/*.ml) $(wildcard $(minc_src)/ml/minc/test/*.ml)
minc_code += $(wildcard $(minc_src)/ml/minc/dune-project) $(wildcard $(minc_src)/ml/minc/minc.opam)
minc_code += $(wildcard $(minc_src)/ml/minc/bin/dune) $(wildcard $(minc_src)/ml/minc/lib/dune) $(wildcard $(minc_src)/ml/minc/test/dune)
minc_code += $(wildcard $(minc_src)/rs/minc/src/*.rs) $(wildcard $(minc_src)/rs/minc/Cargo.toml)
# minc_grammar.txt (a symlink in each <lang>/minc) rides the same rule, so it
# lands in both <lang>/minc and <lang>/orig next to the code.
minc_code += $(foreach L,go jl ml rs,$(wildcard $(minc_src)/$(L)/minc/minc_grammar.txt))

# shared files copied verbatim into the problem dir (relative paths)
# (minc_grammar.txt is NOT here: it is deployed per language, into <lang>/minc and <lang>/orig)
minc_shared := minc.md test/Makefile test/results.csv
minc_shared += $(patsubst $(minc_src)/%,%,$(wildcard $(minc_src)/test/*.c))
minc_shared += $(patsubst $(minc_src)/%,%,$(wildcard $(minc_src)/test/src/*.c))

# --- compiler code: problems/.../<lang>/minc (stubs) + orig (copy) ; answers/.../<lang>/minc (full) ---
# for src = <minc_src>/<lang>/minc/<rel> : stem = <lang>/minc/<rel>, orig = <lang>/orig/<rel>
define minc_code_rule
deploy : problems/minc/minc/$(patsubst $(minc_src)/%,%,$(src))
problems/minc/minc/$(patsubst $(minc_src)/%,%,$(src)) : $(src)
	@mkdir -p $$(@D)
	sed $(sed_problem) $$< > $$@
deploy : problems/minc/minc/$(subst /minc/,/orig/,$(patsubst $(minc_src)/%,%,$(src)))
problems/minc/minc/$(subst /minc/,/orig/,$(patsubst $(minc_src)/%,%,$(src))) : $(src)
	@mkdir -p $$(@D)
	sed $(sed_problem) $$< > $$@
deploy : answers/minc/minc/$(patsubst $(minc_src)/%,%,$(src))
answers/minc/minc/$(patsubst $(minc_src)/%,%,$(src)) : $(src)
	@mkdir -p $$(@D)
	sed $(sed_answer) $$< > $$@
endef
$(foreach src,$(minc_code),$(call EVAL,$(call minc_code_rule)))

# --- shared files copied into the problem dir (problems and answers) ---
define minc_shared_rule
deploy : problems/minc/minc/$(sh)
problems/minc/minc/$(sh) : $(minc_src)/$(sh)
	@mkdir -p $$(@D)
	cp $$< $$@
deploy : answers/minc/minc/$(sh)
answers/minc/minc/$(sh) : $(minc_src)/$(sh)
	@mkdir -p $$(@D)
	cp $$< $$@
endef
$(foreach sh,$(minc_shared),$(call EVAL,$(call minc_shared_rule)))

# --- the problem notebook ---
# Like the other problems, the .py is run through format_string.py first, so
# {out_dir}/{concept}/{problem}/{base} are substituted and {{...}} becomes {...}
# (e.g. the heytutor {{file:...}} placeholders and any literal braces in code).
deploy : problems/minc/minc/minc.ipynb
problems/minc/minc/minc.ipynb : $(minc_src)/minc.py problems/minc/minc/minc.md
	@mkdir -p $(@D)
	./format_string.py $< in_dir=$(in_dir) out_dir=$(prob_dir) concept=minc problem=minc base=minc | $(mk_nb) --syntax py - > $@
deploy : answers/minc/minc/minc.ipynb
answers/minc/minc/minc.ipynb : $(minc_src)/minc.py answers/minc/minc/minc.md
	@mkdir -p $(@D)
	./format_string.py $< in_dir=$(in_dir) out_dir=$(ans_dir) concept=minc problem=minc base=minc | $(mk_nb) --syntax py - > $@

#
# ============================================================
# [2]-[4] problem-set deploy:  ps/ -> problems/ and answers/
# (unchanged; already in the define-rule + foreach style)
# ============================================================
#
deploy :
check :

#
# ps/fundef/compound/go
#
define deploy_code_dir
$(prob_dir)/$(concept)/$(problem)/$(ext) :
	mkdir -p $$@
$(ans_dir)/$(concept)/$(problem)/$(ext) :
	mkdir -p $$@
endef

define deploy_code
#
# ps/fundef/compound/go/compound.go -> problems/fundef/compound/go/compound.go
#
# remove all lines between ... begin hidden ... and ... end hidden ... for problems
#

##### DEPLOY boilerplates #######
deploy : $(prob_dir)/$(concept)/$(problem)/$(ext)/$(base).$(ext)
$(prob_dir)/$(concept)/$(problem)/$(ext)/$(base).$(ext) : $(in_dir)/$(concept)/$(problem)/$(ext)/$(base).$(ext) | $(prob_dir)/$(concept)/$(problem)/$(ext)
ifeq ($(ext),go)
	sed '/\/\*\* begin hidden \*\//,/\/\*\* end hidden \*\//d' $$< > $$@
endif
ifeq ($(ext),jl)
	sed '/### begin hidden/,/### end hidden/d' $$< > $$@
endif
ifeq ($(ext),ml)
	sed '/(\*\* begin hidden \*)/,/(\*\* end hidden \*)/d' $$< > $$@
endif
ifeq ($(ext),rs)
	sed '/\/\*\* begin hidden \*\//,/\/\*\* end hidden \*\//d' $$< > $$@
endif

#
# ps/fundef/compound/go/compound.go -> answers/fundef/compound/go/compound.go
#
# remove lines /** (begin|end) hidden **/
#
##### DEPLOY boilerplates #######
deploy : $(ans_dir)/$(concept)/$(problem)/$(ext)/$(base).$(ext)
$(ans_dir)/$(concept)/$(problem)/$(ext)/$(base).$(ext) : $(in_dir)/$(concept)/$(problem)/$(ext)/$(base).$(ext) | $(ans_dir)/$(concept)/$(problem)/$(ext)
ifeq ($(ext),go)
	sed '/\/\*\* \(begin\|end\) hidden \*\//d' $$< > $$@
endif
ifeq ($(ext),jl)
	sed '/### \(begin\|end\) hidden/d' $$< > $$@
endif
ifeq ($(ext),ml)
	sed '/\(\*\* \(begin\|end\) hidden \*\)/d' $$< > $$@
endif
ifeq ($(ext),rs)
	sed '/\/\*\* \(begin\|end\) hidden \*\//d' $$< > $$@
endif

endef

define check_code
check : $(in_dir)/$(concept)/$(problem)/$(ext)/$(base).ok
#
# ps/fundef/compound/go/compound.go -> ps/fundef/compound/go/compound.exe
#
# compile the source code
#
$(in_dir)/$(concept)/$(problem)/$(ext)/$(base).ok : $(in_dir)/$(concept)/$(problem)/$(ext)/$(base).exe
ifeq ($(concept),how_compiled)
	touch $$@
else
	$(in_dir)/$(concept)/$(problem)/$(ext)/$(base).exe | grep OK && touch $$@
endif
$(in_dir)/$(concept)/$(problem)/$(ext)/$(base).exe : $(in_dir)/$(concept)/$(problem)/$(ext)/$(base).$(ext)
ifeq ($(ext),go)
	go build -o $$@ $$<
endif
ifeq ($(ext),jl)
	echo '#!/usr/bin/env julia -O3' | cat - $$< > $$@
	chmod +x $$@
endif
ifeq ($(ext),ml)
	ocamlopt -O3 $$< -o $$@
endif
ifeq ($(ext),rs)
	rustc -C opt-level=3 --crate-type lib $$< -o $$@
endif
endef

define deploy_md
#
# ps/fundef/compound/go/compound.md -> problems/fundef/compound/compound.md
#
# replace {...}
#
deploy : $(prob_dir)/$(concept)/$(problem)/$(base).md
$(prob_dir)/$(concept)/$(problem) :
	mkdir -p $$@
$(prob_dir)/$(concept)/$(problem)/$(base).md : $(in_dir)/$(concept)/$(problem)/$(base).md $(prob_dir)/$(concept)/$(problem)
	./format_string.py $$< in_dir=$(in_dir) out_dir=$(prob_dir) concept=$(concept) problem=$(problem) base=$(base) > $$@

#
# ps/fundef/compound/go/compound.md -> answers/fundef/compound/compound.md
#
# replace {...}
#
deploy : $(ans_dir)/$(concept)/$(problem)/$(base).md
$(ans_dir)/$(concept)/$(problem) :
	mkdir -p $$@
$(ans_dir)/$(concept)/$(problem)/$(base).md : $(in_dir)/$(concept)/$(problem)/$(base).md $(ans_dir)/$(concept)/$(problem)
	./format_string.py $$< in_dir=$(in_dir) out_dir=$(ans_dir) concept=$(concept) problem=$(problem) base=$(base) > $$@
endef

define deploy_ipynb
#
# ps/fundef/compound/go/compound.py -> problems/fundef/compound/compound.ipynb
#
deploy : $(prob_dir)/$(concept)/$(problem)/$(base).ipynb
##### DEPLOY boilerplates #######
$(prob_dir)/$(concept)/$(problem)/$(base).ipynb : $(in_dir)/$(concept)/$(problem)/$(base).py $(prob_dir)/$(concept)/$(problem)/$(base).md
	./format_string.py $$< in_dir=$(in_dir) out_dir=$(prob_dir) concept=$(concept) problem=$(problem) base=$(base) | $(mk_nb) --syntax py - > $$@

#
# ps/fundef/compound/go/compound.py -> answers/fundef/compound/compound.ipynb
#
##### DEPLOY boilerplates #######
$(ans_dir)/$(concept)/$(problem)/$(base).ipynb : $(in_dir)/$(concept)/$(problem)/$(base).py $(ans_dir)/$(concept)/$(problem)/$(base).md
	./format_string.py $$< in_dir=$(in_dir) out_dir=$(ans_dir) concept=$(concept) problem=$(problem) base=$(base) | $(mk_nb) --syntax py - > $$@

deploy : $(ans_dir)/$(concept)/$(problem)/$(base).ipynb
$(ans_dir)/$(concept)/$(problem)/$(base).html : $(ans_dir)/$(concept)/$(problem)/$(base).ipynb
	jupyter-nbconvert --to html $$<

endef

define deploy_svg_dirs
#
# problems/fundef/compound/svg
#
$(prob_dir)/$(concept)/$(problem)/svg/dir :
	mkdir -p $$@
$(prob_dir)/$(concept)/$(problem)/svg/L/dir :
	mkdir -p $$@

#
# answers/fundef/compound/svg
#
$(ans_dir)/$(concept)/$(problem)/svg/dir :
	mkdir -p $$@
$(ans_dir)/$(concept)/$(problem)/svg/L/dir :
	mkdir -p $$@
endef

define deploy_svg
#
# ps/fundef/compound/svg/*.svg -> problems/fundef/compound/svg/*.svg
#
deploy : $(prob_dir)/$(concept)/$(problem)/svg/$(base).svg
$(prob_dir)/$(concept)/$(problem)/svg/$(base).svg : $(in_dir)/$(concept)/$(problem)/svg/$(base).svg | $(prob_dir)/$(concept)/$(problem)/svg/dir
	cp $$< $$@

#
# ps/fundef/compound/svg/*.svg -> answers/fundef/compound/svg/*.svg
#
deploy : $(ans_dir)/$(concept)/$(problem)/svg/$(base).svg
$(ans_dir)/$(concept)/$(problem)/svg/$(base).svg : $(in_dir)/$(concept)/$(problem)/svg/$(base).svg | $(ans_dir)/$(concept)/$(problem)/svg/dir
	cp $$< $$@
endef

define deploy_svg_L
#
# ps/fundef/compound/svg/L/*.svg -> problems/fundef/compound/svg/L/*.svg
#
deploy : $(prob_dir)/$(concept)/$(problem)/svg/L/$(base).svg
$(prob_dir)/$(concept)/$(problem)/svg/L/$(base).svg : $(in_dir)/$(concept)/$(problem)/svg/L/$(base).svg | $(prob_dir)/$(concept)/$(problem)/svg/L/dir
	cp $$< $$@

#
# ps/fundef/compound/svg/L/*.svg -> answers/fundef/compound/svg/L/*.svg
#
deploy : $(ans_dir)/$(concept)/$(problem)/svg/L/$(base).svg
$(ans_dir)/$(concept)/$(problem)/svg/L/$(base).svg : $(in_dir)/$(concept)/$(problem)/svg/L/$(base).svg | $(ans_dir)/$(concept)/$(problem)/svg/L/dir
	cp $$< $$@
endef

#
# $(call dir_in,D) -> directories inside D
# D/{a,b,c} -> a b c
#
define dir_in
$(shell find $(1) -mindepth 1 -maxdepth 1 -type d -printf "%f\n")
endef

define lang_in
$(shell find $(1) -mindepth 1 -maxdepth 1 -type d -name '??' -printf "%f\n")
endef

#
# $(call ext_in,D,ext) -> basenames of D/*.ext
# D/{a,b,c}.ext -> a b c
#
define ext_in
$(shell test -d $(1) && find $(1) -mindepth 1 -maxdepth 1 -name '*.$(2)' -exec basename -s .$(2) {} +)
endef

ifeq (a,b)
$(foreach concept,$(call dir_in,$(in_dir)), \
 $(foreach problem,$(call dir_in,$(in_dir)/$(concept)), \
  $(foreach base,$(call ext_in,$(in_dir)/$(concept)/$(problem),md),$(call EVAL,$(call deploy_md))) \
  $(foreach base,$(call ext_in,$(in_dir)/$(concept)/$(problem),py),$(call EVAL,$(call deploy_ipynb))) \
  $(if $(call ext_in,$(in_dir)/$(concept)/$(problem)/svg,svg), $(call EVAL,$(call deploy_svg_dirs)) \
   $(foreach base,$(call ext_in,$(in_dir)/$(concept)/$(problem)/svg,svg),$(call EVAL,$(call deploy_svg)))) \
   $(foreach base,$(call ext_in,$(in_dir)/$(concept)/$(problem)/svg/L,svg),$(call EVAL,$(call deploy_svg_L))) \
  $(foreach ext,$(call lang_in,$(in_dir)/$(concept)/$(problem)), \
   $(call EVAL,$(call deploy_code_dir)) \
   $(foreach base,$(call ext_in,$(in_dir)/$(concept)/$(problem)/$(ext),$(ext)),$(call EVAL,$(call deploy_code))) \
   $(foreach base,$(call ext_in,$(in_dir)/$(concept)/$(problem)/$(ext),$(ext)),$(call EVAL,$(call check_code)))) \
))
else
$(foreach concept,hand_compile, \
 $(foreach problem,$(call dir_in,$(in_dir)/$(concept)), \
  $(foreach base,$(call ext_in,$(in_dir)/$(concept)/$(problem),md),$(call EVAL,$(call deploy_md))) \
  $(foreach base,$(call ext_in,$(in_dir)/$(concept)/$(problem),py),$(call EVAL,$(call deploy_ipynb))) \
  $(if $(call ext_in,$(in_dir)/$(concept)/$(problem)/svg,svg), $(call EVAL,$(call deploy_svg_dirs)) \
   $(foreach base,$(call ext_in,$(in_dir)/$(concept)/$(problem)/svg,svg),$(call EVAL,$(call deploy_svg)))) \
   $(foreach base,$(call ext_in,$(in_dir)/$(concept)/$(problem)/svg/L,svg),$(call EVAL,$(call deploy_svg_L))) \
  $(foreach ext,$(call lang_in,$(in_dir)/$(concept)/$(problem)), \
   $(call EVAL,$(call deploy_code_dir)) \
   $(foreach base,$(call ext_in,$(in_dir)/$(concept)/$(problem)/$(ext),$(ext)),$(call EVAL,$(call deploy_code))) \
   $(foreach base,$(call ext_in,$(in_dir)/$(concept)/$(problem)/$(ext),$(ext)),$(call EVAL,$(call check_code)))) \
))
endif

deploy : $(prob_dir)/problem_index.py
$(prob_dir)/problem_index.py : $(in_dir)/problem_index.py
	cp $< $@

deploy : $(ans_dir)/problem_index.py
$(ans_dir)/problem_index.py : $(in_dir)/problem_index.py
	cp $< $@

clean:
	rm -f ps/*/*/*/*~ ps/*/*/*~ ps/*/*/*/*.exe ps/*/*/*/*.cmi ps/*/*/*/*.cmx ps/*/*/*/*.cmo ps/*/*/*/*.ok ps/*/*/*/*.dot ps/*/*/*/*.s ps/*/*/*/*.o

.DELETE_ON_ERROR:
